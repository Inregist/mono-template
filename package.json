{
	"name": "mono-template",
	"private": true,
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "biome lint --write",
		"lint:check": "biome lint",
		"fmt": "biome format --write",
		"fmt:check": "biome format",
		"typecheck": "turbo run check-types",
		"spell": "cspell .",
		"prepare": "lefthook install"
	},
	"packageManager": "pnpm@10.32.1",
  "pnpm": {
    "overrides": {
      "undici": "^7.24.0",
      "lodash": "4.17.23",
      "esbuild": "0.25.0"
    }
  },
	"devDependencies": {
		"@biomejs/biome": "2.4.4",
		"cspell": "^9.7.0",
		"lefthook": "^2.1.4",
		"turbo": "^2.8.16",
		"typescript": "5.9.2"
	}
}
