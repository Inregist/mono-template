{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"composite": true,
		"outDir": "./dist",
		"declaration": true,
		"declarationMap": true,
		"esModuleInterop": true
	},
	"include": ["src/**/*.ts", "src/**/*.tsx"]
}
