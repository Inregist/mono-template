		"pg": "^8.20.0",
		"postgres": "^3.4.8",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^24.1.0",
		"@types/pg": "^8.18.0",
		"auth": "^1.5.5",
		"better-auth": "^1.5.5",
		"drizzle-kit": "^0.31.9",
		"tsx": "^4.21.0"
	}
}
