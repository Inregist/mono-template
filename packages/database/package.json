{
	"name": "@repo/database",
	"version": "0.0.0",
	"private": true,
	"exports": {
		".": "./src/index.ts"
	},
	"scripts": {
		"db:auth-generate": "auth generate --config ../../apps/api/better-auth.config.ts --output src/schema/auth.ts",
